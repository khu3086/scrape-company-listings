# Copy to .env and fill in. Load with:  set -a; source .env; set +a
# Then run:  .venv/bin/python scrape.py

# The Gmail address you send FROM (needs an App Password, see README).
SENDER_GMAIL=youraddress@gmail.com

# 16-character Google App Password (NOT your normal Gmail password).
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Where alerts are delivered. Defaults to khushi.nigamwork@gmail.com if unset.
RECIPIENT=khushi.nigamwork@gmail.com
